<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:tb="https://notifyicon.com/"
             xmlns:local="clr-namespace:SlippiTV.Client"
             xmlns:vm="clr-namespace:SlippiTV.Client.ViewModels"
             xmlns:converters="clr-namespace:SlippiTV.Client.Converters"
             xmlns:mi="http://www.aathifmahir.com/dotnet/2022/maui/icons"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:service="clr-namespace:SlippiTV.Shared.Service;assembly=SlippiTV.Shared"
             x:Class="SlippiTV.Client.FriendsPage"
             x:DataType="{x:Type vm:FriendsViewModel}">
    <ContentPage.Resources>
        <ResourceDictionary>
            <mi:MauiIcon Icon="{mi:FluentFilled Icon=AddCircle24Filled}" IconColor="#10FA94" x:Key="AddIcon"/>
            <toolkit:EnumToBoolConverter x:Key="LiveStatusToVisibilityConverter">
                <toolkit:EnumToBoolConverter.TrueValues>
                    <service:LiveStatus>Active</service:LiveStatus>
                </toolkit:EnumToBoolConverter.TrueValues>
            </toolkit:EnumToBoolConverter>
            <toolkit:IsNotNullConverter x:Key="IsNotNullConverter"/>
            <converters:LiveStatusToColorConverter x:Key="LiveStatusToColorConverter"/>
            <converters:LiveStatusToToolTipConverter x:Key="LiveStatusToToolTipConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid Margin="0,8,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid RowSpacing="10" Margin="0,0,0,10" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="AddFriendsButton"
                    FontSize="18" Text="Add Friends by Connect Code" Grid.Column="0" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#222222, Dark=#FAFAFA}" CornerRadius="12"
                    Margin="0,0,0,0" Padding="6,0,12,0" Clicked="AddFriendsButton_Clicked" BackgroundColor="{AppThemeBinding Light=#FaFaFa, Dark=#333333}">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup Name="CommonStates">
                            <VisualState Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value="1"/>
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState Name="PointerOver">
                                <VisualState.Setters>
                                    <Setter Property="Opacity" Value=".85"/>
                                    <Setter Property="Scale" Value=".98"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
                <Button.ImageSource>
                    <FontImageSource Glyph="{mi:FluentFilled Icon=AddCircle24Filled, IconColor=#10FA94}" Size="32"/>
                </Button.ImageSource>
            </Button>
            <!--<Button x:Name="AddFromRecentButton" Clicked="AddFromRecentButton_Clicked"
                        Text="Add from recent" FontSize="12" TextColor="{AppThemeBinding Light=#222222, Dark=#FAFAFA}"
                        MinimumHeightRequest="0" MinimumWidthRequest="0" BackgroundColor="{AppThemeBinding Light=#FaFaFa, Dark=#333333}" Padding="8,0,12,0" Grid.Column="2" CornerRadius="12">
                <Button.ImageSource>
                    <FontImageSource Glyph="{mi:FluentFilled Icon=AddCircle24Filled, IconColor=#10FA94}" Size="20"/>
                </Button.ImageSource>
            </Button>-->
        </Grid>
        <CollectionView ItemsSource="{Binding Friends}" Grid.Row="1">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="{x:Type vm:FriendViewModel}">
                    <VerticalStackLayout Spacing="4" Padding="10,0,10,6">
                        <BoxView HeightRequest="1" Color="#333333"/>
                        <Grid Padding="0,0,0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>


                            <HorizontalStackLayout Grid.Column="0" Grid.Row="0" HorizontalOptions="Start">
                                <ImageButton Clicked="WatchFriendButton_Clicked" IsEnabled="{Binding LiveStatus, Converter={StaticResource LiveStatusToVisibilityConverter}}"
                                            VerticalOptions="Center" Margin="0" Padding="-4, 6, 0, 0" BackgroundColor="Transparent" >
                                    <ImageButton.Source>
                                        <FontImageSource Glyph="{mi:FluentFilled Icon=Tv24Filled, IconColor={AppThemeBinding Light=#AAAAAA, Dark=#CCCCCC}}" />
                                    </ImageButton.Source>
                                </ImageButton>

  
                                
                                <HorizontalStackLayout Grid.Column="1" Grid.Row="0" HorizontalOptions="End" Margin="-8,0,0,0">
                                    <Image MaximumHeightRequest="14" VerticalOptions="Center" Margin="0,4,0,0" ToolTipProperties.Text="Active Viewers">
                                        <Image.Source>
                                            <FontImageSource Glyph="{mi:FluentFilled Icon=Person24Filled, IconColor={StaticResource StatusGreen}}"/>
                                        </Image.Source>
                                    </Image>

                                    <Label IsVisible="True" 
                                       FontSize="10" VerticalTextAlignment="Center" Padding="2,4,12,2" Grid.Column="2" Grid.ColumnSpan="1" Margin="0" HorizontalOptions="Start">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <!--Span Text="{Binding ActiveGameInfo.CurrentViewerCount}" TextColor="{StaticResource StatusGreen}"/>-->
                                                    <Span Text="23" TextColor="{StaticResource StatusGreen}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="Start">
                                <Label Text="{Binding ConnectCode}" FontAttributes="Bold" FontSize="24" VerticalTextAlignment="Center"/>
                                <Image MaximumHeightRequest="18" VerticalOptions="Center" Margin="6,0,0,0" ToolTipProperties.Text="{Binding LiveStatus, Converter={StaticResource LiveStatusToToolTipConverter}}">
                                    <Image.Source>
                                        <FontImageSource Glyph="{mi:FluentFilled Icon=Circle24Filled}" Color="{Binding LiveStatus, Converter={StaticResource LiveStatusToColorConverter}}"/>
                                    </Image.Source>
                                </Image>

                                <Label IsVisible="{Binding ActiveGameInfo, Converter={StaticResource IsNotNullConverter}}" 
                                       FontSize="10" VerticalTextAlignment="Center" Padding="12,0,0,2" Grid.Column="2" Grid.ColumnSpan="1" Margin="0" HorizontalOptions="Start">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Playing Game "/>
                                            <Span Text="{Binding ActiveGameInfo.GameNumber}"/>
                                            <Span Text=" vs. "/>
                                            <Span Text="{Binding ActiveGameInfo.OpponentDisplayName}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </HorizontalStackLayout>
                                


                            <ImageButton x:Name="FriendsMore" VerticalOptions="Center" Margin="0" Padding="0,8,0,0" Grid.Column="3" HorizontalOptions="End">
                                <ImageButton.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="FriendsMore_Tapped" NumberOfTapsRequired="1"/>
                                </ImageButton.GestureRecognizers>
                                <ImageButton.Source>
                                    <FontImageSource Glyph="{mi:FluentFilled Icon=MoreHorizontal24Filled, IconColor={AppThemeBinding Light=#AAAAAA, Dark=#CCCCCC}}"/>
                                </ImageButton.Source>
                            </ImageButton>

                        </Grid>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <local:BottomBar Grid.Row="3" BindingContext="{Binding ShellViewModel}" HeightRequest="20"/>
        
        <tb:TaskbarIcon
            IconSource="slippitv.ico"
            LeftClickCommand="{Binding ShowHideWindowCommand}"
            NoLeftClickDelay="True"
            x:Name="TaskbarIcon">
            <FlyoutBase.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem Command="{Binding ShowHideWindowCommand}" Text="Reveal Window" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem Command="{Binding ExitApplicationCommand}" Text="Quit" />
                </MenuFlyout>
            </FlyoutBase.ContextFlyout>
        </tb:TaskbarIcon>
    </Grid>
</ContentPage>
